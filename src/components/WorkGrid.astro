---
const projects = [
  { title: 'Project One',   tags: ['Web App', 'Python'] },
  { title: 'Project Two',   tags: ['API Design', 'TypeScript'] },
  { title: 'Project Three', tags: ['Open Source', 'Tooling'] },
];
---

<div class="section-header" id="work">
  <span class="section-title">Selected Work</span>
  <span class="section-count">{String(projects.length).padStart(2, '0')} Projects</span>
</div>

<div class="work-grid">
  {projects.map((project, i) => (
    <div class="work-card">
      <div class="card-num">{String(i + 1).padStart(2, '0')} / {String(projects.length).padStart(2, '0')}</div>
      <h2 class="card-title">{project.title}</h2>
      <div class="card-tags">
        {project.tags.map(tag => <span class="tag">{tag}</span>)}
      </div>
      <span class="card-arrow">↗</span>
    </div>
  ))}
</div>

<style>
  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 60px 0 40px;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.9s forwards;
  }

  .section-title {
    font-size: 0.7rem;
    font-family: 'DM Mono', monospace;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--warm-mid);
  }

  .section-count {
    font-size: 0.7rem;
    font-family: 'DM Mono', monospace;
    color: var(--line);
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    margin-bottom: 1px;
    opacity: 0;
    animation: fadeUp 0.9s ease 1.1s forwards;
  }

  .work-card {
    background: var(--cream);
    padding: 40px 32px;
    transition: background 0.3s ease;
    cursor: none;
  }

  .work-card:hover { background: var(--ink); }

  .card-num {
    font-family: 'DM Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    color: var(--warm-mid);
    margin-bottom: 48px;
    transition: color 0.3s ease;
  }

  .work-card:hover .card-num { color: rgba(255,255,255,0.3); }

  .card-title {
    font-size: 1.9rem;
    font-weight: 300;
    line-height: 1.15;
    margin-bottom: 16px;
    transition: color 0.3s ease;
  }

  .work-card:hover .card-title { color: var(--cream); }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 32px;
  }

  .tag {
    font-family: 'DM Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--warm-mid);
    border: 1px solid var(--line);
    padding: 4px 10px;
    transition: color 0.3s ease, border-color 0.3s ease;
  }

  .work-card:hover .tag {
    color: rgba(255,255,255,0.4);
    border-color: rgba(255,255,255,0.1);
  }

  .card-arrow {
    font-size: 1.2rem;
    color: var(--rust);
    transition: transform 0.3s ease;
    display: inline-block;
  }

  .work-card:hover .card-arrow { transform: translateX(6px) translateY(-6px); }

  @media (max-width: 768px) {
    .work-grid { grid-template-columns: 1fr; }
  }
</style>